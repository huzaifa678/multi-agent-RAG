# Dockerfile for Memory RAG server
FROM base:v1

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY mcp_servers/rag /app/mcp_servers/rag
COPY utils /app/utils
COPY rag /app/rag
COPY .env /app/.env

EXPOSE 8001

CMD ["uvicorn", "mcp_servers.rag.server:app", "--host", "0.0.0.0", "--port", "8001", "--reload"]