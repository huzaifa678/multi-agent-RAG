# Dockerfile for Memory MCP server 
FROM base:v1

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY mcp_servers/memory /app/mcp_servers/memory
COPY utils /app/utils
COPY memory /app/memory

EXPOSE 8003

CMD ["uvicorn", "mcp_servers.memory.server:app", "--host", "0.0.0.0", "--port", "8003", "--reload"]
